# llm.hostbun.cc — two-lane OpenAI router + docs + computed price endpoint
#   host docs.llm.hostbun.cc -> docs page
#   /local/*      -> local LM Studio at llm.bofrid.dev (pbox gemma); no key
#   /docs*        -> docs page
#   /prices(.json)-> computed actual prices (refreshed from crazyrouter)
#   /*            -> crazyrouter.com full API, key injected
{
	admin off
	auto_https off
}
:80 {
	@docs host docs.llm.hostbun.cc
	handle @docs {
		root * /srv
		rewrite * /docs/index.html
		file_server
	}
	handle_path /local/* {
		reverse_proxy https://llm.bofrid.dev {
			header_up Host llm.bofrid.dev
		}
	}
	handle /docs* {
		root * /srv
		rewrite * /docs/index.html
		file_server
	}
	# Computed actual prices (discount applied); refreshed on boot + every 6h
	handle /prices.json {
		root * /srv
		file_server
	}
	handle /prices {
		root * /srv
		rewrite * /prices.json
		file_server
	}
	handle {
		reverse_proxy https://crazyrouter.com {
			header_up Host crazyrouter.com
			header_up Authorization "Bearer {$CRAZYROUTER_KEY}"
		}
	}
}
