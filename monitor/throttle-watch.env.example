# throttle-watch config — copy to throttle-watch.env on the host, chmod 600, NEVER commit.
# Real values live only on pbox (/home/philip/monitor/throttle-watch.env) and in keyvault.

ROUTER_URL=https://llm.hostbun.cc
ROUTER_PW=ddash                        # router panel password (kv: adminPassword)

# Telegram — @ddbofridemailBot (kv: telegram/devdash-channel). Primary = Philip's DM;
# the DM 400s until Philip presses Start on the bot, so delivery falls back to the channel.
TG_TOKEN=                              # kv: telegram/devdash-channel .alert_sender_token
TG_CHAT=7803034119                     # Philip DM
TG_FALLBACK_CHAT=-1003904394398        # devdash channel

# Email via AWS SES (kv: mailmcp/.env::AWS_*). Sender must be an SES-verified identity.
MAIL_FROM=auth@mejl.to
MAIL_TO=philip@bofrid.se
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# Thresholds
GPU_PCT=90            # page when pbox GPU memory >= this % of total
RL_PCT=92             # page when an account's 5h or 7d usage window >= this %
OOM_WINDOW_MIN=12     # only page OOM kills newer than this many minutes
REMIND_MIN=60         # re-page a still-active condition every N minutes
STATE_FILE=/home/philip/monitor/throttle-watch.state.json
